{
  "name": "@agentos/cli",
  "version": "0.1.0",
  "description": "CLI for AgentOS - try, build, and manage AI agents",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "agentos": "./bin/run.js"
  },
  "files": [
    "dist",
    "bin",
    "README.md"
  ],
  "scripts": {
    "build": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\" && tsc",
    "dev": "tsc --watch",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "test": "echo 'CLI tests run via workspace root'"
  },
  "keywords": [
    "ai",
    "agents",
    "cli",
    "agentos",
    "claude"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/dev-sanidhya/AgentOS"
  },
  "dependencies": {
    "@agentos/agents": "workspace:*",
    "@agentos/dashboard": "workspace:*",
    "chalk": "^4.1.2",
    "commander": "^12.0.0",
    "dotenv": "^16.4.1",
    "inquirer": "^8.2.5",
    "ora": "^5.4.1"
  },
  "devDependencies": {
    "@types/inquirer": "^8.2.10",
    "@types/node": "^20.11.0",
    "typescript": "^5.3.3"
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
